<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <include
        domain="sharedpref"
        path="." />
    <include
        domain="database"
        path="." />
    <include
        domain="file"
        path="imported" />
    <include
        domain="file"
        path="pending" />
    <include
        domain="file"
        path="clash/override.json" />

    <!-- Exclude sensitive data from backup -->
    <exclude
        domain="sharedpref"
        path="yt_xboard_session.xml" />
    <exclude
        domain="sharedpref"
        path="yt_offline_cache.xml" />
    <exclude
        domain="sharedpref"
        path="yt_secure_prefs.xml" />
    <exclude
        domain="sharedpref"
        path="yt_subscription_alerts.xml" />
</full-backup-content>
