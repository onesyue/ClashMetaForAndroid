<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Production: only trust system CA certificates -->
    <base-config>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Debug builds can additionally trust user-installed certificates for testing -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
