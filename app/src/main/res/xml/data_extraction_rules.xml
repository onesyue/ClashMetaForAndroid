<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ (API 31+) backup/transfer rules -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="." />
        <include domain="database" path="." />
        <include domain="file" path="imported" />
        <include domain="file" path="pending" />
        <include domain="file" path="clash/override.json" />
        <!-- Exclude sensitive data -->
        <exclude domain="sharedpref" path="yt_xboard_session.xml" />
        <exclude domain="sharedpref" path="yt_offline_cache.xml" />
        <exclude domain="sharedpref" path="yt_secure_prefs.xml" />
        <exclude domain="sharedpref" path="yt_subscription_alerts.xml" />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="." />
        <include domain="database" path="." />
        <include domain="file" path="imported" />
        <include domain="file" path="pending" />
        <include domain="file" path="clash/override.json" />
        <exclude domain="sharedpref" path="yt_xboard_session.xml" />
        <exclude domain="sharedpref" path="yt_offline_cache.xml" />
        <exclude domain="sharedpref" path="yt_secure_prefs.xml" />
        <exclude domain="sharedpref" path="yt_subscription_alerts.xml" />
    </device-transfer>
</data-extraction-rules>
