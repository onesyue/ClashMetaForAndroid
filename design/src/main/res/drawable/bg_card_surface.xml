<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base glass layer: translucent dark -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#801A2332" />
            <corners android:radius="24dp" />
            <stroke android:width="0.5dp" android:color="#30FFFFFF" />
        </shape>
    </item>
    <!-- Top highlight: simulates light refraction on glass surface -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#18FFFFFF"
                android:centerColor="#08FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270"
                android:type="linear" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <!-- Inner border glow -->
    <item
        android:left="0.5dp"
        android:top="0.5dp"
        android:right="0.5dp"
        android:bottom="0.5dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <corners android:radius="23.5dp" />
            <stroke android:width="0.5dp" android:color="#0CFFFFFF" />
        </shape>
    </item>
</layer-list>
