<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base glass -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#991A2332" />
            <corners android:radius="28dp" />
            <stroke android:width="0.5dp" android:color="#35FFFFFF" />
        </shape>
    </item>
    <!-- Top edge highlight -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#1AFFFFFF"
                android:centerColor="#08FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270"
                android:type="linear" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <!-- Inner glow border -->
    <item
        android:left="0.5dp"
        android:top="0.5dp"
        android:right="0.5dp"
        android:bottom="0.5dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <corners android:radius="27.5dp" />
            <stroke android:width="0.5dp" android:color="#0AFFFFFF" />
        </shape>
    </item>
</layer-list>
