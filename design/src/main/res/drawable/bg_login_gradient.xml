<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/color_background"
                android:endColor="@color/color_background"
                android:type="linear"
                android:angle="270" />
        </shape>
    </item>
    <!-- Top-center radial glow (primary color ambient) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#185B5FE6"
                android:endColor="#00000000"
                android:gradientRadius="450dp"
                android:centerX="0.5"
                android:centerY="0.2"
                android:type="radial" />
        </shape>
    </item>
    <!-- Bottom-right subtle secondary glow -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#107C6FE0"
                android:endColor="#00000000"
                android:gradientRadius="350dp"
                android:centerX="0.8"
                android:centerY="0.85"
                android:type="radial" />
        </shape>
    </item>
</layer-list>
