<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glass circle base -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:startColor="@color/color_primary"
                android:endColor="@color/color_primary_variant"
                android:angle="135"
                android:type="linear" />
        </shape>
    </item>
    <!-- Glass shine -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:startColor="#40FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
