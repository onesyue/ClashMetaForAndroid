<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Top row: status + toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="@string/application_name" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status_disconnected"
                android:textColor="@color/color_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_profile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tap_to_start"
                android:textColor="@color/color_text_secondary"
                android:textSize="12sp"
                android:singleLine="true"
                android:ellipsize="end" />

        </LinearLayout>

        <ImageView
            android:id="@+id/widget_toggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_baseline_flash_on"
            android:contentDescription="@string/tap_to_start"
            android:padding="8dp"
            android:background="@drawable/bg_pill_toggle" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_divider"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp" />

    <!-- Speed row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Download -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↓ Download"
                android:textSize="10sp"
                android:textColor="@color/color_text_tertiary" />

            <TextView
                android:id="@+id/widget_download_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 B/s"
                android:textSize="16sp"
                android:textColor="@color/color_status_good"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Upload -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↑ Upload"
                android:textSize="10sp"
                android:textColor="@color/color_text_tertiary" />

            <TextView
                android:id="@+id/widget_upload_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 B/s"
                android:textSize="16sp"
                android:textColor="@color/color_primary"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Traffic section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/show_traffic"
            android:textSize="11sp"
            android:textColor="@color/color_text_secondary" />

        <ProgressBar
            android:id="@+id/widget_traffic_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/bg_progress_bar" />

        <TextView
            android:id="@+id/widget_traffic_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textSize="11sp"
            android:textColor="@color/color_text_secondary" />

    </LinearLayout>

    <!-- Connection info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="10dp">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_baseline_vpn_lock"
            android:tint="@color/color_status_good"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/widget_encryption"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="@string/security_encrypted"
            android:textSize="11sp"
            android:textColor="@color/color_text_tertiary"
            android:singleLine="true" />

        <TextView
            android:id="@+id/widget_uptime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--:--"
            android:textSize="11sp"
            android:textColor="@color/color_text_tertiary" />

    </LinearLayout>

</LinearLayout>
