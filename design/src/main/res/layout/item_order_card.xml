<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#801A2332"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#30FFFFFF"
    app:strokeWidth="0.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header: plan name + status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/order_plan_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#F1F5F9"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/order_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Period -->
        <TextView
            android:id="@+id/order_period"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#94A3B8"
            android:textSize="13sp" />

        <!-- Coupon -->
        <TextView
            android:id="@+id/order_coupon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#9B8AFB"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:background="#20FFFFFF" />

        <!-- Discount -->
        <TextView
            android:id="@+id/order_discount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:textColor="#34D399"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- Surplus -->
        <TextView
            android:id="@+id/order_surplus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:textColor="#6E72FC"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- Bottom: date + amount -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/order_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#8494A7"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/order_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F1F5F9"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Cancel button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/order_cancel_btn"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:text="@string/order_cancel_btn"
            android:textColor="#EF4444"
            android:textSize="13sp"
            android:visibility="gone"
            app:strokeColor="#EF4444" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
