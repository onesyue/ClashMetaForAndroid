<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable name="self"              type="com.github.kr328.clash.design.MainDesign" />
        <variable name="clashRunning"      type="boolean" />
        <variable name="forwarded"         type="String" />
        <variable name="mode"              type="String" />
        <variable name="profileName"       type="String" />
        <variable name="colorConnected"    type="int" />
        <variable name="colorDisconnected" type="int" />
        <variable name="userEmail"         type="String" />
        <variable name="expiryDate"        type="String" />
        <variable name="trafficText"       type="String" />
        <variable name="connectionTime"    type="String" />
        <variable name="downloadSpeed"     type="String" />
        <variable name="uploadSpeed"       type="String" />

        <import type="android.view.View" />
        <import type="android.content.res.ColorStateList" />
        <import type="com.github.kr328.clash.design.MainDesign.Request" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/bg_gradient_main"
        android:paddingStart="@{self.surface.insets.start}"
        android:paddingEnd="@{self.surface.insets.end}">

        <!-- ══ 顶部标题栏（所有标签页共用） ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="@{self.surface.insets.top}"
            android:paddingStart="20dp"
            android:paddingEnd="8dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/xboard_brand_name"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.03"
                    android:textColor="#1A237E" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/vpn_subtitle"
                    android:textSize="12sp"
                    android:textColor="#5C7CAB" />

            </LinearLayout>

            <ImageButton
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_notification"
                android:tint="#3A6BBF"
                android:contentDescription="@null"
                android:padding="8dp" />

            <ImageButton
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_baseline_settings"
                android:tint="#3A6BBF"
                android:contentDescription="@string/settings"
                android:padding="8dp"
                android:onClick="@{() -> self.request(Request.OpenSettings)}" />

            <!-- 头像首字母圆（文字由代码设置） -->
            <TextView
                android:id="@+id/avatar_letter_header"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:gravity="center"
                android:background="@drawable/bg_avatar"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:text="U" />

        </LinearLayout>

        <!-- ══ 三标签页内容区域 ══ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- ── 标签1：首页 ── -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/home_content"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:overScrollMode="never">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="24dp">

                    <!-- 用户信息卡 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="@android:color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="16dp">

                            <!-- 头像 -->
                            <TextView
                                android:id="@+id/avatar_letter_card"
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                android:gravity="center"
                                android:background="@drawable/bg_avatar"
                                android:textColor="@android:color/white"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:text="U" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <!-- 邮箱 + 续费按钮 -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="@{userEmail}"
                                            android:textSize="14sp"
                                            android:textStyle="bold"
                                            android:textColor="#1A237E"
                                            android:maxLines="1"
                                            android:ellipsize="end" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="@{expiryDate}"
                                            android:textSize="12sp"
                                            android:textColor="#5C7CAB"
                                            android:layout_marginTop="2dp" />

                                    </LinearLayout>

                                    <com.google.android.material.button.MaterialButton
                                        style="@style/Widget.MaterialComponents.Button.TextButton"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/renew_button"
                                        android:textSize="12sp"
                                        android:onClick="@{() -> self.request(Request.OpenAccount)}"
                                        app:icon="@drawable/ic_baseline_replay"
                                        app:iconSize="14dp"
                                        app:iconPadding="4dp"
                                        app:cornerRadius="20dp" />

                                </LinearLayout>

                                <!-- 流量用量文字 -->
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@{trafficText}"
                                    android:textSize="11sp"
                                    android:textColor="#5C7CAB"
                                    android:layout_marginTop="8dp" />

                                <!-- 流量进度条（进度由代码设置） -->
                                <ProgressBar
                                    android:id="@+id/traffic_progress"
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="6dp"
                                    android:max="100"
                                    android:progressDrawable="@drawable/bg_progress_bar"
                                    android:layout_marginTop="4dp" />

                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- VPN 连接卡 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="@android:color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:paddingTop="32dp"
                            android:paddingBottom="28dp">

                            <!-- 发光环 + 电源按钮 -->
                            <FrameLayout
                                android:layout_width="180dp"
                                android:layout_height="180dp"
                                android:layout_gravity="center_horizontal">

                                <View
                                    android:layout_width="180dp"
                                    android:layout_height="180dp"
                                    android:background="@drawable/bg_connect_button_ring"
                                    android:backgroundTint="@{ColorStateList.valueOf(clashRunning ? colorConnected : colorDisconnected)}"
                                    android:alpha="0.12" />

                                <View
                                    android:layout_width="152dp"
                                    android:layout_height="152dp"
                                    android:layout_gravity="center"
                                    android:background="@drawable/bg_connect_button_ring"
                                    android:backgroundTint="@{ColorStateList.valueOf(clashRunning ? colorConnected : colorDisconnected)}"
                                    android:alpha="0.22" />

                                <FrameLayout
                                    android:layout_width="128dp"
                                    android:layout_height="128dp"
                                    android:layout_gravity="center"
                                    android:background="@drawable/bg_connect_button"
                                    android:backgroundTint="@{ColorStateList.valueOf(clashRunning ? colorConnected : colorDisconnected)}"
                                    android:clickable="true"
                                    android:focusable="true"
                                    android:foreground="?attr/selectableItemBackgroundBorderless"
                                    android:onClick="@{() -> self.request(Request.ToggleStatus)}"
                                    android:elevation="6dp">

                                    <ImageView
                                        android:layout_width="52dp"
                                        android:layout_height="52dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_power_button"
                                        android:tint="@android:color/white" />

                                </FrameLayout>

                            </FrameLayout>

                            <!-- 连接状态文字 -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="20dp"
                                android:text="@{clashRunning ? @string/status_connected : @string/status_disconnected}"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@{clashRunning ? colorConnected : colorDisconnected}" />

                            <!-- 提示文字（未连接时显示） -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="@string/click_to_connect_hint"
                                android:textSize="12sp"
                                android:textColor="#8EAACB"
                                android:visibility="@{clashRunning ? View.GONE : View.VISIBLE}" />

                            <!-- 连接时长（连接时显示） -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@{connectionTime}"
                                android:textSize="13sp"
                                android:textColor="#5C7CAB"
                                android:fontFamily="monospace"
                                android:visibility="@{clashRunning ? View.VISIBLE : View.GONE}" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- 连接状态卡（连接时显示） -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:visibility="@{clashRunning ? View.VISIBLE : View.GONE}"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="@android:color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@{forwarded}"
                                android:textSize="12sp"
                                android:textColor="#8EAACB"
                                android:visibility="@{forwarded != null ? View.VISIBLE : View.GONE}" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="8dp">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:gravity="center_horizontal">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/download_label"
                                        android:textSize="12sp"
                                        android:textColor="#5C7CAB" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@{downloadSpeed}"
                                        android:textSize="15sp"
                                        android:textStyle="bold"
                                        android:textColor="#1A237E"
                                        android:layout_marginTop="2dp" />

                                </LinearLayout>

                                <View
                                    android:layout_width="1dp"
                                    android:layout_height="36dp"
                                    android:layout_gravity="center_vertical"
                                    android:background="#E0EAF8" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:gravity="center_horizontal">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/upload_label"
                                        android:textSize="12sp"
                                        android:textColor="#5C7CAB" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@{uploadSpeed}"
                                        android:textSize="15sp"
                                        android:textStyle="bold"
                                        android:textColor="#1A237E"
                                        android:layout_marginTop="2dp" />

                                </LinearLayout>

                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- 代理模式卡 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:onClick="@{() -> self.request(Request.OpenProxy)}"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="@android:color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="12dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_baseline_apps"
                                android:tint="#3A6BBF"
                                android:layout_marginEnd="10dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/proxy"
                                android:textSize="13sp"
                                android:textColor="#8EAACB"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@{mode != null ? mode : @string/rule_mode}"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#1A237E" />

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_chevron_right"
                                android:tint="#8EAACB" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- 节点选择卡 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="@android:color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <!-- 标题行 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingStart="16dp"
                                android:paddingEnd="12dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="10dp">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/node_selection_title"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:textColor="#1A237E" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/view_all_nodes"
                                    android:textSize="12sp"
                                    android:textColor="#3A6BBF"
                                    android:background="?attr/selectableItemBackground"
                                    android:padding="4dp"
                                    android:onClick="@{() -> self.request(Request.OpenProxy)}" />

                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="0.5dp"
                                android:background="#E0EAF8"
                                android:layout_marginStart="16dp"
                                android:layout_marginEnd="16dp" />

                            <!-- 香港 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="52dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingStart="16dp"
                                android:paddingEnd="14dp"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true"
                                android:onClick="@{() -> self.request(Request.OpenProxy)}">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/node_hk"
                                    android:textSize="14sp"
                                    android:textColor="#1A237E" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_chevron_right"
                                    android:tint="#C5D8F0" />

                            </LinearLayout>

                            <!-- 日本 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="52dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingStart="16dp"
                                android:paddingEnd="14dp"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true"
                                android:onClick="@{() -> self.request(Request.OpenProxy)}">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/node_jp"
                                    android:textSize="14sp"
                                    android:textColor="#1A237E" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_chevron_right"
                                    android:tint="#C5D8F0" />

                            </LinearLayout>

                            <!-- 新加坡 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="52dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingStart="16dp"
                                android:paddingEnd="14dp"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true"
                                android:onClick="@{() -> self.request(Request.OpenProxy)}">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/node_sg"
                                    android:textSize="14sp"
                                    android:textColor="#1A237E" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_chevron_right"
                                    android:tint="#C5D8F0" />

                            </LinearLayout>

                            <!-- 美国 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="52dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingStart="16dp"
                                android:paddingEnd="14dp"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true"
                                android:onClick="@{() -> self.request(Request.OpenProxy)}">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/node_us"
                                    android:textSize="14sp"
                                    android:textColor="#1A237E" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_chevron_right"
                                    android:tint="#C5D8F0" />

                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </androidx.core.widget.NestedScrollView>

            <!-- ── 标签2：商店 ── -->
            <LinearLayout
                android:id="@+id/store_content"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_baseline_extension"
                    android:tint="#B0C8E8"
                    android:alpha="0.7" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/store_coming_soon"
                    android:textSize="15sp"
                    android:textColor="#8EAACB"
                    android:gravity="center" />

            </LinearLayout>

            <!-- ── 标签3：我的 ── -->
            <LinearLayout
                android:id="@+id/profile_content"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/nav_profile"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#1A237E" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="@android:color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_person"
                                android:tint="#3A6BBF"
                                android:layout_marginEnd="12dp" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/profile"
                                    android:textSize="11sp"
                                    android:textColor="#8EAACB" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@{profileName != null ? profileName : @string/xboard_login_summary}"
                                    android:textSize="14sp"
                                    android:textColor="#1A237E" />

                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.button.MaterialButton
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:onClick="@{() -> self.request(Request.OpenAccount)}"
                        android:text="@string/xboard_do_login"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:onClick="@{() -> self.request(Request.OpenProfiles)}"
                        android:text="@string/profiles"
                        app:cornerRadius="12dp" />

                </LinearLayout>

            </LinearLayout>

        </FrameLayout>

        <!-- ══ 底部导航栏 ══ -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:paddingBottom="@{self.surface.insets.bottom}"
            app:menu="@menu/menu_main_nav"
            app:labelVisibilityMode="labeled"
            app:itemIconTint="@color/selector_bottom_nav_icon"
            app:itemTextColor="@color/selector_bottom_nav_icon" />

    </LinearLayout>

</layout>
