<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable name="self"              type="com.github.kr328.clash.design.MainDesign" />
        <variable name="clashRunning"      type="boolean" />
        <variable name="forwarded"         type="String" />
        <variable name="mode"              type="String" />
        <variable name="profileName"       type="String" />
        <variable name="colorConnected"    type="int" />
        <variable name="colorDisconnected" type="int" />

        <import type="android.view.View" />
        <import type="android.content.res.ColorStateList" />
        <import type="com.github.kr328.clash.design.MainDesign.Request" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/bg_gradient_main"
        android:paddingStart="@{self.surface.insets.start}"
        android:paddingEnd="@{self.surface.insets.end}">

        <!-- 顶栏（所有 Tab 共用） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="@{self.surface.insets.top}"
            android:paddingStart="20dp"
            android:paddingEnd="8dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/brand_name_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/xboard_brand_name"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#1A237E"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless" />


            </LinearLayout>

            <!-- 设置通过连续点击品牌名 5 次进入（隐藏入口） -->

            <TextView
                android:id="@+id/avatar_letter_header"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:gravity="center"
                android:background="@drawable/bg_avatar"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:text="U" />

        </LinearLayout>

        <!-- Tab 内容区 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- Tab 1: 首页 -->
            <ScrollView
                android:id="@+id/home_content"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:overScrollMode="never"
                android:fillViewport="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="24dp">

                    <!-- 用户信息卡 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="@android:color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="16dp">

                            <TextView
                                android:id="@+id/avatar_letter_card"
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                android:gravity="center"
                                android:background="@drawable/bg_avatar"
                                android:textColor="@android:color/white"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:text="U" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:id="@+id/email_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/xboard_login_summary"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="#1A237E"
                                    android:maxLines="1"
                                    android:ellipsize="end" />

                                <TextView
                                    android:id="@+id/expiry_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/expiry_unknown"
                                    android:textSize="12sp"
                                    android:textColor="#5C7CAB"
                                    android:layout_marginTop="2dp" />

                                <TextView
                                    android:id="@+id/traffic_label"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/traffic_usage_label"
                                    android:textSize="11sp"
                                    android:textColor="#5C7CAB"
                                    android:layout_marginTop="8dp" />

                                <ProgressBar
                                    android:id="@+id/traffic_progress"
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="6dp"
                                    android:max="100"
                                    android:progress="0"
                                    android:progressDrawable="@drawable/bg_progress_bar"
                                    android:layout_marginTop="4dp" />

                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- VPN 连接卡 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="@android:color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:paddingTop="32dp"
                            android:paddingBottom="28dp">

                            <FrameLayout
                                android:layout_width="180dp"
                                android:layout_height="180dp"
                                android:layout_gravity="center_horizontal">

                                <View
                                    android:layout_width="180dp"
                                    android:layout_height="180dp"
                                    android:background="@drawable/bg_connect_button_ring"
                                    android:backgroundTint="@{ColorStateList.valueOf(clashRunning ? colorConnected : colorDisconnected)}"
                                    android:alpha="0.12" />

                                <View
                                    android:layout_width="152dp"
                                    android:layout_height="152dp"
                                    android:layout_gravity="center"
                                    android:background="@drawable/bg_connect_button_ring"
                                    android:backgroundTint="@{ColorStateList.valueOf(clashRunning ? colorConnected : colorDisconnected)}"
                                    android:alpha="0.22" />

                                <FrameLayout
                                    android:layout_width="128dp"
                                    android:layout_height="128dp"
                                    android:layout_gravity="center"
                                    android:background="@drawable/bg_connect_button"
                                    android:backgroundTint="@{ColorStateList.valueOf(clashRunning ? colorConnected : colorDisconnected)}"
                                    android:clickable="true"
                                    android:focusable="true"
                                    android:foreground="?attr/selectableItemBackgroundBorderless"
                                    android:onClick="@{() -> self.request(Request.ToggleStatus)}"
                                    android:elevation="6dp">

                                    <ImageView
                                        android:layout_width="52dp"
                                        android:layout_height="52dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_power_button"
                                        android:tint="@android:color/white" />

                                </FrameLayout>

                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="20dp"
                                android:text="@{clashRunning ? @string/status_connected : @string/status_disconnected}"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@{ColorStateList.valueOf(clashRunning ? colorConnected : colorDisconnected)}" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="@string/click_to_connect_hint"
                                android:textSize="12sp"
                                android:textColor="#8EAACB"
                                android:visibility="@{clashRunning ? View.GONE : View.VISIBLE}" />

                            <TextView
                                android:id="@+id/connection_time_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="00:00:00"
                                android:textSize="13sp"
                                android:textColor="#5C7CAB"
                                android:fontFamily="monospace"
                                android:visibility="@{clashRunning ? View.VISIBLE : View.GONE}" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- 连接速度卡（连接时显示） -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:visibility="@{clashRunning ? View.VISIBLE : View.GONE}"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="@android:color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@{forwarded}"
                                android:textSize="12sp"
                                android:textColor="#8EAACB"
                                android:visibility="@{forwarded != null ? View.VISIBLE : View.GONE}" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="8dp">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:gravity="center_horizontal">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/download_label"
                                        android:textSize="12sp"
                                        android:textColor="#5C7CAB" />

                                    <TextView
                                        android:id="@+id/download_speed_text"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0 B/s"
                                        android:textSize="15sp"
                                        android:textStyle="bold"
                                        android:textColor="#1A237E"
                                        android:layout_marginTop="2dp" />

                                </LinearLayout>

                                <View
                                    android:layout_width="1dp"
                                    android:layout_height="36dp"
                                    android:layout_gravity="center_vertical"
                                    android:background="#E0EAF8" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:gravity="center_horizontal">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/upload_label"
                                        android:textSize="12sp"
                                        android:textColor="#5C7CAB" />

                                    <TextView
                                        android:id="@+id/upload_speed_text"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0 B/s"
                                        android:textSize="15sp"
                                        android:textStyle="bold"
                                        android:textColor="#1A237E"
                                        android:layout_marginTop="2dp" />

                                </LinearLayout>

                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- 代理模式 + 节点选择（合并卡） -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:onClick="@{() -> self.request(Request.OpenProxy)}"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="@android:color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <!-- 代理模式行 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingStart="16dp"
                                android:paddingEnd="12dp">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_baseline_apps"
                                    android:tint="#3A6BBF"
                                    android:layout_marginEnd="10dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/proxy"
                                    android:textSize="13sp"
                                    android:textColor="#8EAACB"
                                    android:layout_marginEnd="8dp" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@{mode != null ? mode : @string/rule_mode}"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="#1A237E" />

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_chevron_right"
                                    android:tint="#8EAACB" />

                            </LinearLayout>

                            <!-- 分隔线 -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="0.5dp"
                                android:background="#E0EAF8"
                                android:layout_marginStart="16dp"
                                android:layout_marginEnd="16dp" />

                            <!-- 节点选择行 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="52dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingStart="16dp"
                                android:paddingEnd="12dp">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_notification"
                                    android:tint="#3A6BBF"
                                    android:layout_marginEnd="10dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/node_selection_title"
                                    android:textSize="13sp"
                                    android:textColor="#8EAACB"
                                    android:layout_marginEnd="8dp" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@{profileName != null ? profileName : @string/not_selected}"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="#1A237E"
                                    android:maxLines="1"
                                    android:ellipsize="end" />

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_chevron_right"
                                    android:tint="#8EAACB" />

                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </ScrollView>

            <!-- Tab 2: 商店 (immediately navigates to StoreActivity) -->
            <LinearLayout
                android:id="@+id/store_content"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">
            </LinearLayout>

            <!-- Tab 3: 我的 -->
            <ScrollView
                android:id="@+id/profile_content"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:overScrollMode="never"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="24dp">

                    <!-- 页面标题 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/nav_profile"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#1A237E"
                        android:layout_marginBottom="12dp" />

                    <!-- 用户头部卡片 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="@android:color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="16dp">

                            <TextView
                                android:id="@+id/profile_avatar_letter"
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:gravity="center"
                                android:background="@drawable/bg_avatar"
                                android:textColor="@android:color/white"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:text="U" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:id="@+id/profile_header_email_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/xboard_login_summary"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:textColor="#1A237E"
                                    android:maxLines="1"
                                    android:ellipsize="end" />

                                <TextView
                                    android:id="@+id/profile_header_plan_badge"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/plan_unknown"
                                    android:textSize="12sp"
                                    android:textColor="#3A6BBF"
                                    android:layout_marginTop="4dp" />

                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- 套餐信息卡 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="@android:color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="8dp">

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_person"
                                    android:tint="#3A6BBF"
                                    android:layout_marginEnd="8dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/plan_label"
                                    android:textSize="12sp"
                                    android:textColor="#8EAACB" />

                                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

                                <TextView
                                    android:id="@+id/profile_plan_name_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/plan_unknown"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    android:textColor="#1A237E" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="10dp">

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_baseline_replay"
                                    android:tint="#3A6BBF"
                                    android:layout_marginEnd="8dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/expiry_prefix"
                                    android:textSize="12sp"
                                    android:textColor="#8EAACB" />

                                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

                                <TextView
                                    android:id="@+id/profile_expiry_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="--"
                                    android:textSize="13sp"
                                    android:textColor="#1A237E" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="4dp">

                                <TextView
                                    android:id="@+id/profile_traffic_label"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/traffic_usage_label"
                                    android:textSize="11sp"
                                    android:textColor="#5C7CAB" />

                                <TextView
                                    android:id="@+id/profile_traffic_detail_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=""
                                    android:textSize="11sp"
                                    android:textColor="#5C7CAB" />

                            </LinearLayout>

                            <ProgressBar
                                android:id="@+id/profile_traffic_progress"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="6dp"
                                android:max="100"
                                android:progress="0"
                                android:progressDrawable="@drawable/bg_progress_bar" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- 余额卡 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="@android:color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center_horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/balance_label"
                                    android:textSize="11sp"
                                    android:textColor="#8EAACB" />

                                <TextView
                                    android:id="@+id/profile_balance_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="¥ --"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="#1A237E"
                                    android:layout_marginTop="4dp" />

                            </LinearLayout>

                            <View
                                android:layout_width="1dp"
                                android:layout_height="40dp"
                                android:layout_gravity="center_vertical"
                                android:background="#E0EAF8" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center_horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/commission_label"
                                    android:textSize="11sp"
                                    android:textColor="#8EAACB" />

                                <TextView
                                    android:id="@+id/profile_commission_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="¥ --"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="#1A237E"
                                    android:layout_marginTop="4dp" />

                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- 邀请卡 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/profile_invite_card"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="@android:color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/invite_link_label"
                                    android:textSize="12sp"
                                    android:textColor="#8EAACB" />

                                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

                                <TextView
                                    android:id="@+id/profile_referral_count_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="已邀请 0 人"
                                    android:textSize="12sp"
                                    android:textColor="#3A6BBF" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="#F5F8FF"
                                android:padding="10dp"
                                android:layout_marginTop="2dp">

                                <TextView
                                    android:id="@+id/profile_invite_link_text"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="--"
                                    android:textSize="12sp"
                                    android:textColor="#5C7CAB"
                                    android:maxLines="1"
                                    android:ellipsize="end" />

                                <TextView
                                    android:id="@+id/profile_copy_invite_btn"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/copy_text"
                                    android:textSize="12sp"
                                    android:textColor="#3A6BBF"
                                    android:background="?attr/selectableItemBackground"
                                    android:padding="6dp"
                                    android:layout_marginStart="8dp" />

                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- 修改密码按钮 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/profile_change_password_btn"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:text="@string/change_password"
                        app:cornerRadius="12dp" />

                    <!-- 退出登录按钮 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/profile_logout_btn"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/logout"
                        android:textColor="#D32F2F"
                        app:strokeColor="#D32F2F"
                        app:cornerRadius="12dp" />

                </LinearLayout>

            </ScrollView>

        </FrameLayout>

        <!-- 底部导航 -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:paddingBottom="@{self.surface.insets.bottom}"
            app:menu="@menu/menu_main_nav"
            app:labelVisibilityMode="labeled" />

    </LinearLayout>

</layout>
